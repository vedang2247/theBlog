<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Document</title>
</head>
<body>
    <%- include("./partials/nav") %>
    <div class="container mt-4">
        <h1><%= blog.title %></h1>
        <img src="<%= blog.coverPicURL %>" alt="Imagedoasiufh" width="400px">
        <div class="container m-2">
        <img src="<%= blog.createdBy.ProfilePicUrl %>" alt="Author Profile Pic" width="100px">
        <p>- <%= blog.createdBy.FullName %></p>
        </div>
    </div>
    <div class="container mt-3">
        <pre><%= blog.body %></pre>
    </div>
    <div class="container mt-3">
        <h1>Comment</h1>
        <% if (user) { %>
            <form action="/blog/comment/<%= blog._id %>" method="post">
                <div class="mb-3">
                    <input type="text" name="content" class="form-control" placeholder="Enter your Comment">
                    <button class="btn btn-sm btn-primary m-2" type="submit">Post</button>
                </div>
            </form>
        <% } else { %>
            <p>Please <a href="/user/signin">sign in</a> to comment.</p>
        <% } %>
    </div>
    <div class="container mt-3">
        <% comments.forEach(com => { %>
         <img src="<%= com.createdBy.ProfilePicUrl %>" alt="Author Profile Pic" width="50px">
         <%= com.createdBy.FullName %>
         <pre><%= com.content %></pre>
        <% }) %>
    </div>
    <%- include("./partials/scripts") %>
</body>
</html>